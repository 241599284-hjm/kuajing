NODE_ENV=development

# Local ports
STOREFRONT_PORT=3000
ADMIN_PORT=3001
API_GATEWAY_PORT=4000
ADMIN_GATEWAY_PORT=4001
STORE_SERVICE_PORT=4101
AUTH_SERVICE_PORT=4102
CATALOG_SERVICE_PORT=4103
INVENTORY_SERVICE_PORT=4104
ORDER_SERVICE_PORT=4105
PAYMENT_SERVICE_PORT=4106
SUPPORT_SERVICE_PORT=4107
MEDIA_SERVICE_PORT=4108
WORKER_SERVICE_PORT=4109
NOTIFICATION_SERVICE_PORT=4111
ORDER_SERVICE_URL=http://localhost:4105
PAYMENT_SERVICE_URL=http://localhost:4106
INVENTORY_SERVICE_URL=http://localhost:4104
WORKER_SERVICE_URL=http://localhost:4109
MEDIA_SERVICE_URL=http://localhost:4108
NOTIFICATION_SERVICE_URL=http://localhost:4111

# Local databases
POSTGRES_USER=commerce
POSTGRES_PASSWORD=commerce
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
APP_DATABASE_URL=postgresql://commerce:commerce@localhost:5432/app_db
ORDER_DATABASE_URL=postgresql://commerce:commerce@localhost:5432/order_db
INVENTORY_DATABASE_URL=postgresql://commerce:commerce@localhost:5432/inventory_db
NOTIFICATION_DATABASE_URL=postgresql://commerce:commerce@localhost:5432/notification_db
LEDGER_DATABASE_URL=postgresql://commerce:commerce@localhost:5432/ledger_db

# Local infra
REDIS_URL=redis://localhost:6379
OPENSEARCH_URL=http://localhost:9200
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MAILPIT_SMTP_HOST=localhost
MAILPIT_SMTP_PORT=1025
AUTH_EMAIL_FROM=Demo Teaware <no-reply@demo-teaware.local>
AUTH_EMAIL_FROM_ADDRESS=no-reply@demo-teaware.local
AUTH_EMAIL_FROM_NAME=Demo Teaware
AUTH_EMAIL_DELIVERY_MODE=notification-service
AUTH_VERIFY_BASE_URL=http://localhost:4102
STOREFRONT_PUBLIC_URL=http://localhost:3000
NEXT_PUBLIC_AUTH_SERVICE_URL=http://localhost:4102
NEXT_PUBLIC_API_GATEWAY_URL=http://localhost:4000
NEXT_PUBLIC_ADMIN_GATEWAY_URL=http://localhost:4001

# Local observability
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
LOKI_URL=http://localhost:3100
SLOW_ORDER_CREATE_MS=2000
SLOW_INVENTORY_RESERVE_MS=1000
SLOW_CATALOG_READ_MS=500

# Cloud handoff rule: production uses managed state services.
# RDS/managed Redis/object storage values override local defaults in server deployments.
CACHE_KEY_PREFIX=local
OBJECT_STORAGE_PROVIDER=minio
OBJECT_STORAGE_BUCKET=demo-teaware-media
OBJECT_STORAGE_CDN_URL=http://localhost:9000/demo-teaware-media
MEDIA_PUBLIC_BASE_URL=http://localhost:4108/files
MEDIA_LOCAL_STORAGE_ROOT=storage/media
MEDIA_MAX_UPLOAD_BYTES=8388608

# Default self-operated store
DEFAULT_STORE_ID=00000000-0000-4000-8000-000000000001
DEFAULT_STORE_SLUG=demo-teaware
DEFAULT_STORE_REGION=local
DEFAULT_STORE_TIMEZONE=Asia/Hong_Kong
