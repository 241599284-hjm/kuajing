{
  "name": "crossborder-commerce-kit",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.31.0",
  "scripts": {
    "dev": "turbo run dev --parallel --filter=@commerce/storefront --filter=@commerce/admin --filter=@commerce/api-gateway --filter=@commerce/admin-gateway --filter=@commerce/store-service --filter=@commerce/auth-service --filter=@commerce/catalog-service --filter=@commerce/media-service --filter=@commerce/support-service --filter=@commerce/order-service --filter=@commerce/payment-service --filter=@commerce/inventory-service --filter=@commerce/worker-service --filter=@commerce/logistics-service --filter=@commerce/notification-service --filter=@commerce/review-service --filter=@commerce/ops-service --filter=@commerce/product-import-service",
    "dev:all": "turbo run dev --parallel",
    "build": "turbo run build",
    "e2e": "playwright test",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "db:reset": "docker compose down -v && docker compose up -d postgres",
    "check": "pnpm lint && pnpm typecheck && pnpm test"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "turbo": "^2.6.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.0"
  }
}
